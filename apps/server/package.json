{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "bun --watch src/index.ts",
		"start": "bun src/index.ts",
		"db:seed": "bun src/seed.ts"
	},
	"dependencies": {
		"@buenasmigas/api": "workspace:*",
		"@buenasmigas/auth": "workspace:*",
		"@buenasmigas/db": "workspace:*",
		"@buenasmigas/env": "workspace:*",
		"@fastify/cors": "^11.0.1",
		"@fastify/helmet": "^13.0.1",
		"@fastify/rate-limit": "^10.2.2",
		"@fastify/static": "^8.1.1",
		"drizzle-orm": "^0.45.1",
		"exceljs": "^4.4.0",
		"@orpc/openapi": "catalog:",
		"@orpc/server": "catalog:",
		"@orpc/zod": "catalog:",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"fastify": "^5.3.3",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@buenasmigas/config": "workspace:*",
		"@types/bun": "latest",
		"@types/node": "catalog:",
		"tsdown": "^0.21.9",
		"tsx": "^4.19.2",
		"typescript": "catalog:"
	}
}
