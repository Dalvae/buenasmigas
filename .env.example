# Variables para el deploy (Dokploy → panel de Environment).
# NO commitear el .env real.

# Dominio público de la app (se usa para el SPA, CORS y Better Auth)
APP_URL=https://buenasmigas.dalvae.cl

# Postgres
POSTGRES_PASSWORD=cambia-esta-clave

# Secreto de Better Auth (mínimo 32 caracteres). Genera uno aleatorio.
BETTER_AUTH_SECRET=genera-un-secreto-de-al-menos-32-caracteres

# Admin inicial (creado por el seed en el primer arranque).
# ADMIN_PASSWORD es obligatoria (sin default) y debe tener al menos 12 caracteres.
ADMIN_EMAIL=admin@buenasmigas.cl
ADMIN_PASSWORD=cambia-esta-clave
ADMIN_NAME=Administrador
